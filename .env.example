# Copy this file to .env (same folder) and fill in your keys.
# PawOS reads .env from: next to PawOS.exe (installed builds), or the
# project root (dev checkout). Never commit the real .env file.

GEMINI_API_KEY=

# Google OAuth credentials (Google Cloud Console → Credentials).
# GOOGLE_REDIRECT_URI must exactly match a redirect URI registered on this
# OAuth client, and must be pawos-web's hosted /auth/google/callback route
# (e.g. https://pawos.revantaai.com/auth/google/callback) — that route
# relays the resulting code back to this app over a fixed local port (see
# LOCAL_RELAY_PORT in src/main/auth/GoogleOAuthFlow.ts). It is NOT a
# loopback URL itself; Google always redirects the system browser to a real
# public HTTPS page. GOOGLE_CLIENT_SECRET is required for a "Web
# application" type client; a "Desktop app" type client doesn't use one.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://pawos.revantaai.com/auth/google/callback

# Supabase — only the values Supabase itself marks safe to expose to a
# client (Project URL + the Publishable/anon key; RLS policies enforce
# security on these, not secrecy). NEVER put the Secret/Service Role key
# here — that belongs only on a real backend server, never in a desktop
# app's .env, since anyone with the installed app could extract it.
SUPABASE_URL=https://krqdxdguqaoehrxhmggz.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_E3vh2q3V3Sj-h7TY341D6Q_EmEneDwQ

# GitHub sign-in (src/main/auth/GitHubOAuthFlow.ts) — Supabase itself is the
# OAuth client (GitHub Client ID/Secret configured in the Supabase
# dashboard's GitHub provider, not here). GITHUB_REDIRECT_URI is the
# `redirectTo` passed to supabase.auth.signInWithOAuth() and must be both
# (a) pawos-web's hosted /auth/github/callback route, which relays the code
# back to this app over a fixed local port, and (b) present in Supabase's
# project "Redirect URLs" allowlist (Authentication → URL Configuration).
GITHUB_REDIRECT_URI=https://pawos.revantaai.com/auth/github/callback

# Signing secret for password-reset tokens (src/main/mail/passwordResetToken.ts).
# Optional — if unset, a random secret is generated once and persisted to
# userData on first use. Set this explicitly for a stable secret across a
# clean reinstall/data wipe.
EMAIL_SIGNING_SECRET=

# Infrastructure Runtime connectors — all optional. Each is only registered
# as "configured" when its token is present; Paw always tells you honestly
# when a capability needs one of these rather than guessing or faking a
# result. Add a token here to let Paw operate that real system on your
# behalf (never hardcode these anywhere else).

# Source control — personal access token with repo read (+ contents/commit
# read) scope. GitHub: Settings → Developer settings → Personal access tokens.
GITHUB_TOKEN=
# GitLab: User Settings → Access Tokens, scope: read_api, read_repository.
GITLAB_TOKEN=
GITLAB_URL=https://gitlab.com

# Project management / ticketing.
# Linear: Settings → API → Personal API keys.
LINEAR_API_KEY=
# Jira: id.atlassian.com API token + your site's base URL + the account email
# the token belongs to (Jira Cloud auth is basic auth: email + API token).
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# Hosting platforms — used to deploy/check status/roll back when no project-
# specific deploy script exists (see RunDeployScriptPlugin, which always
# takes priority when a project already has its own deploy command).
VERCEL_TOKEN=
NETLIFY_TOKEN=
# Optional — only needed for getLatestDeployment/rollback (not for the first
# deploy, which links a site automatically). Netlify → Site settings → General.
NETLIFY_SITE_ID=

# Railway — token from https://railway.app/account/tokens. Project/service id
# are only needed for status/rollback/promote (the first deploy works with
# just the token).
RAILWAY_TOKEN=
RAILWAY_PROJECT_ID=
RAILWAY_SERVICE_ID=

# Google Cloud Run — requires `gcloud auth login` already run on this machine;
# PawOS never manages GCP credentials itself, only shells to your own
# authenticated gcloud CLI.
GCP_CLOUD_RUN_SERVICE=
GCP_PROJECT_ID=
GCP_REGION=

# AWS Elastic Beanstalk — requires `aws configure`/`aws sso login` already run
# on this machine. Deploys by zipping the project, uploading it to
# AWS_EB_S3_BUCKET, and pointing AWS_EB_ENVIRONMENT at the new version — the
# bucket and application/environment must already exist in your AWS account.
AWS_EB_APPLICATION=
AWS_EB_ENVIRONMENT=
AWS_EB_S3_BUCKET=
AWS_EB_REGION=

# Docker / VPS — requires `ssh <DEPLOY_SSH_HOST>` to already work without a
# password prompt (key-based auth), Docker installed on both this machine and
# the remote host, and the project to already have its own Dockerfile.
DEPLOY_SSH_HOST=
DEPLOY_IMAGE_NAME=
DEPLOY_CONTAINER_NAME=
DEPLOY_PORT_MAPPING=

# Hostinger — shared/business/cloud hosting plans expose SFTP, not a deploy
# API. Add an SSH public key in hPanel → Advanced → SSH Access first (this
# connector never handles a password); PawOS then shells to the standard
# `sftp` CLI already built into Windows/macOS/Linux. No deployment history,
# rollback, or staging slot exists on plain SFTP hosting, so those calls
# honestly report unsupported.
HOSTINGER_SFTP_HOST=
HOSTINGER_SFTP_USER=
HOSTINGER_SFTP_PORT=
HOSTINGER_REMOTE_PATH=
# Optional — cosmetic only, shown as the deploy URL in Paw's replies.
HOSTINGER_SITE_URL=

# GitHub Pages — reuses GITHUB_TOKEN (same token as the source control/CI
# connectors above; needs `repo` scope to push to GITHUB_PAGES_REPO). Deploys
# by force-pushing the built output to a gh-pages branch, the standard way to
# publish to Pages without GitHub Actions. No staging/production distinction
# exists, so promote() honestly reports that rather than fabricating one.
GITHUB_PAGES_REPO=
GITHUB_PAGES_BRANCH=

# ---------------------------------------------------------------------------
# Cloud VM provisioning connectors — these actually launch a real, billable
# VM via each provider's official already-authenticated CLI, then deploy to
# it over SSH + Docker (auto-installing Docker via get.docker.com if it isn't
# already there). PawOS remembers the one instance it provisioned per
# provider (see ProvisionedInstanceStore) so later deploys reuse it instead
# of launching a new VM every time. None of these auto-tear-down instances —
# stopping/deleting one is up to you in the provider's own console/CLI.
# ---------------------------------------------------------------------------

# AWS EC2 — requires `aws configure`/`aws sso login`, plus an EC2 key pair
# that already exists in your account (`aws ec2 import-key-pair`) — EC2 has
# no inline-public-key injection the way GCE/Azure do.
AWS_EC2_AMI_ID=
AWS_EC2_KEY_NAME=
AWS_EC2_INSTANCE_TYPE=
AWS_EC2_SECURITY_GROUP_ID=
AWS_EC2_SUBNET_ID=
AWS_EC2_REGION=
AWS_EC2_IMAGE_NAME=
AWS_EC2_CONTAINER_NAME=
AWS_EC2_PORT_MAPPING=
AWS_EC2_SSH_USER=

# Google Compute Engine (raw VM) — requires `gcloud auth login`. Your local
# SSH public key is injected into instance metadata automatically; no
# provider-side key registration needed.
GCE_INSTANCE_NAME=
GCE_ZONE=
GCE_MACHINE_TYPE=
GCE_IMAGE_FAMILY=
GCE_IMAGE_PROJECT=
GCE_IMAGE_NAME=
GCE_CONTAINER_NAME=
GCE_PORT_MAPPING=
GCE_SSH_USER=

# Azure VM — requires `az login`. Uses your local SSH public key if present
# (~/.ssh/id_ed25519.pub or id_rsa.pub), otherwise lets az generate one.
AZURE_VM_NAME=
AZURE_RESOURCE_GROUP=
AZURE_VM_LOCATION=
AZURE_VM_SIZE=
AZURE_VM_IMAGE=
AZURE_VM_IMAGE_NAME=
AZURE_VM_CONTAINER_NAME=
AZURE_VM_PORT_MAPPING=
AZURE_VM_SSH_USER=

# DigitalOcean — requires `doctl auth init`, plus an SSH key already added
# to your DO account (`doctl compute ssh-key create` or the dashboard).
DIGITALOCEAN_DROPLET_NAME=
DIGITALOCEAN_SSH_KEY_ID=
DIGITALOCEAN_REGION=
DIGITALOCEAN_SIZE=
DIGITALOCEAN_IMAGE=
DIGITALOCEAN_IMAGE_NAME=
DIGITALOCEAN_CONTAINER_NAME=
DIGITALOCEAN_PORT_MAPPING=
DIGITALOCEAN_SSH_USER=

# Linode (Akamai) — requires `linode-cli configure`. Your local SSH public
# key is injected directly (authorized_keys) — no pre-registration needed.
LINODE_LABEL=
LINODE_REGION=
LINODE_TYPE=
LINODE_IMAGE=
LINODE_IMAGE_NAME=
LINODE_CONTAINER_NAME=
LINODE_PORT_MAPPING=
LINODE_SSH_USER=

# Vultr — requires vultr-cli to already have an API key configured, plus an
# SSH key already added to your Vultr account (`vultr-cli ssh-key create`).
VULTR_HOSTNAME=
VULTR_SSH_KEY_ID=
VULTR_REGION=
VULTR_PLAN=
VULTR_OS_ID=
VULTR_IMAGE_NAME=
VULTR_CONTAINER_NAME=
VULTR_PORT_MAPPING=
VULTR_SSH_USER=

# Hetzner Cloud — requires `hcloud context create`, plus an SSH key already
# added to your Hetzner account (`hcloud ssh-key create`).
HETZNER_SERVER_NAME=
HETZNER_SSH_KEY_NAME=
HETZNER_LOCATION=
HETZNER_SERVER_TYPE=
HETZNER_IMAGE=
HETZNER_IMAGE_NAME=
HETZNER_CONTAINER_NAME=
HETZNER_PORT_MAPPING=
HETZNER_SSH_USER=

# Oracle Cloud Infrastructure — requires `oci setup config`. OCI genuinely
# needs all of these OCIDs to launch an instance; nothing here is simplified
# away. Your local SSH public key is injected via OCI's real
# ssh_authorized_keys instance-metadata mechanism.
OCI_INSTANCE_NAME=
OCI_AVAILABILITY_DOMAIN=
OCI_COMPARTMENT_ID=
OCI_SUBNET_ID=
OCI_IMAGE_ID=
OCI_SHAPE=
OCI_IMAGE_NAME=
OCI_CONTAINER_NAME=
OCI_PORT_MAPPING=
OCI_SSH_USER=

# Hostinger VPS — uses Hostinger's real public API (developers.hostinger.com)
# with a Bearer token generated in hPanel. Deliberately does NOT auto-
# purchase a new VPS (that's a real monthly charge) — HOSTINGER_VPS_ID must
# already be an existing, already-purchased VPS. This connector attaches
# your local SSH public key to it via the real API, then deploys over SSH.
HOSTINGER_API_TOKEN=
HOSTINGER_VPS_ID=
HOSTINGER_VPS_IMAGE_NAME=
HOSTINGER_VPS_CONTAINER_NAME=
HOSTINGER_VPS_PORT_MAPPING=
HOSTINGER_VPS_SSH_USER=

# ---------------------------------------------------------------------------
# New PaaS adapters
# ---------------------------------------------------------------------------

# Kubernetes — requires `kubectl config current-context` to already point at
# the right cluster. KUBERNETES_MANIFEST_PATH must be a real manifest
# already committed to the project (relative to its path, or absolute) —
# PawOS never generates Kubernetes YAML on your behalf.
KUBERNETES_MANIFEST_PATH=
KUBERNETES_DEPLOYMENT_NAME=
KUBERNETES_NAMESPACE=
KUBERNETES_SERVICE_NAME=

# Azure App Service — requires `az login`. Deploys via Azure's real zip-
# deploy mechanism. AZURE_APP_SERVICE_STAGING_SLOT is optional; without it,
# deploy() targets production directly and rollback/promote honestly report
# there's no slot to swap.
AZURE_APP_SERVICE_NAME=
AZURE_APP_SERVICE_RESOURCE_GROUP=
AZURE_APP_SERVICE_LOCATION=
AZURE_APP_SERVICE_PLAN_SKU=
AZURE_APP_SERVICE_RUNTIME=
AZURE_APP_SERVICE_STAGING_SLOT=

# Render — API key from the Render dashboard. Render's real deploy model is
# Git-connected (no folder-upload API), so deploy() triggers a build from
# the already-connected repo's latest commit rather than uploading projectPath.
RENDER_API_KEY=
RENDER_SERVICE_ID=

# Fly.io — requires `fly auth login`, plus a real fly.toml already in the
# project (from `fly launch`, run once by you — PawOS never scaffolds one).
FLYIO_APP_NAME=

{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],

    "module": "commonjs",

    "moduleResolution": "node",

    "outDir": "dist/main",
    "rootDir": "src",

    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    "types": ["node"],

    "resolveJsonModule": true,
    "sourceMap": true,
    "noUncheckedIndexedAccess": true,

    "ignoreDeprecations": "5.0"
  },
  "include": [
    "src/main/**/*.ts",
    "src/shared/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}